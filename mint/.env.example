# Cascade Mint Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# MINT CONFIGURATION
# =============================================================================

# Master seed for the mint (32-byte hex string)
# Generate with: openssl rand -hex 32
MINT_PRIVATE_KEY=

# =============================================================================
# DATABASE
# =============================================================================

# SQLite database path (relative to WorkingDirectory)
# Default: data/cascade_mint.db
DATABASE_URL=sqlite:///data/cascade_mint.db

# =============================================================================
# LND / LIGHTNING CONFIGURATION
# =============================================================================

# LND gRPC endpoint
LND_GRPC_URL=https://localhost:10009

# Path to LND TLS certificate
LND_CERT_PATH=/opt/cascade-mint/certs/tls.cert

# Path to LND admin macaroon (hex-encoded)
LND_MACAROON_PATH=/opt/cascade-mint/macaroons/admin.macaroon

# Optional: absolute path to lncli when it is not on PATH
LND_CLI_PATH=/usr/local/bin/lncli

# Alternative: Hex-encoded macaroon directly
# LND_MACAROON=

# =============================================================================
# LOGGING
# =============================================================================

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# Enable backtrace on panic
RUST_BACKTRACE=1

# =============================================================================
# NETWORK
# =============================================================================

# Host to bind to (default: 127.0.0.1 for localhost only)
# Set to 0.0.0.0 for external access (behind reverse proxy)
HOST=127.0.0.1

# Port to listen on
PORT=8080

# =============================================================================
# NOSTR (Optional)
# =============================================================================

# Nostr relay URLs for trade event publishing (comma-separated)
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# =============================================================================
# SECURITY
# =============================================================================

# CORS allowed origins (comma-separated, no spaces)
# CORS_ORIGINS=https://cascade.f7z.io,https://www.cascade.f7z.io

# Enable rate limiting
ENABLE_RATE_LIMIT=true

# =============================================================================
# METRICS & MONITORING
# =============================================================================

# Enable Prometheus metrics endpoint
# METRICS_ENABLED=true
# METRICS_PORT=9090

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================

# Set to "true" to use mock Lightning (for testing only!)
# MOCK_LIGHTNING=true
