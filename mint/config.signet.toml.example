[mint]
url = "http://127.0.0.1:3342"
name = "Cascade Signet Mint"
description = "Paper trading mint for Cascade signet"

[database]
path = "./data/signet/cascade_mint.db"

[seed]
path = "./data/signet/mint_seed.key"

[lnd]
host = "127.0.0.1"
port = 10009
cert_path = "/Users/customer/.lnd/tls.cert"
macaroon_path = "/Users/customer/.lnd/data/chain/bitcoin/signet/admin.macaroon"
cli_path = "/Users/customer/bin/lncli"

[stripe]
secret_key = ""
webhook_secret = ""
success_url = "https://signet.cascade.f7z.io/portfolio?stripe=success&topup_id={TOPUP_ID}"
cancel_url = "https://signet.cascade.f7z.io/portfolio?stripe=cancel&topup_id={TOPUP_ID}"
base_url = "https://api.stripe.com"
checkout_expiry_seconds = 1800
product_name = "Cascade Portfolio Top-up"
max_topup_minor = 10000
window_limit_minor = 25000
window_seconds = 86400
allowed_risk_levels = ["normal"]

[network]
network_type = "signet"

[server]
host = "127.0.0.1"
port = 3342

[fees]
trade_fee_percent = 1
