# Cascade Mint Configuration

[mint]
# Mint URL for Cashu API
url = "http://localhost:8080"

# Network (bitcoin, signet, regtest)
network = "bitcoin"

# Liquidity parameter for LMSR market maker
liquidity = 1000.0

# Default market expiry (in days)
default_expiry_days = 90

[mint.keysets]
# Default keyset for the mint
default = "default"

[server]
# Listen address and port
host = "0.0.0.0"
port = 8080

# Timeout settings
request_timeout_secs = 30

[database]
# SQLite database path
path = "./data/mint.db"

# Enable migrations
auto_migrate = true

[lnd]
# Enable Lightning via LND
enabled = false

# LND gRPC host
host = "localhost:10009"

# TLS certificate path
tls_cert_path = ""

# Admin macaroon path
macaroon_path = ""

[nostr]
# Enable Nostr integration
enabled = true

# Relay URLs for market event publishing
relay_urls = ["wss://relay.damus.io", "wss://relay.nostr.bg"]

# Private key for signing (hex encoded)
private_key = ""

[logging]
# Log level (trace, debug, info, warn, error)
level = "info"

# Log format (json, pretty)
format = "json"
