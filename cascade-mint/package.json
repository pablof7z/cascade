{
  "name": "cascade-mint",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "wrangler pages dev ../dist/assets  --compatibility-date=2024-01-01 --port 8787",
    "deploy": "npm run build && wrangler pages deploy ../dist/assets",
    "db:migrate": "wrangler d1 migrations apply cascade-mint --local"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^4.0.0-rc3",
    "@cloudflare/workers-types": "^4.20241127.0",
    "hono": "^4.6.10",
    "hono-rate-limiter": "^0.4.0",
    "libsql": "^0.4.0",
    "@noble/curves": "^1.4.0",
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^3.91.0"
  }
}
