# Cashu Mint Configuration

# Master seed for BIP-32 key derivation (hex-encoded, 32 bytes)
# Generate with: openssl rand -hex 32
MASTER_SEED=

# Turso Database (libsql)
TURSO_URL=libsql://cascade-mint-your-org.turso.io
TURSO_AUTH_TOKEN=

# Cashu Configuration
CASHU_FEE_RATE=1

# Nostr Configuration  
NOSTR_RELAYS=wss://relay.damus.io,wss://relay.nostr.band,wss://nos.lol,wss://relay.snort.social
NOSTR_PUBKEY=

# NIP-46 Delegation (optional, for signing on behalf of user)
DELEGATOR_PUBKEY=
DELEGATOR_TOKEN=

# Environment
NODE_ENV=development
