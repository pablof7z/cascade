# Cascade Mint Configuration
# The Cashu mint URL for ecash deposits and withdrawals.
# Set this to your Cascade-compatible mint URL.
# Defaults to https://mint.cascade.market if not set.
VITE_CASCADE_MINT_URL=https://mint.cascade.market

# Network Mode (optional)
# Set to 'false' to enable mainnet mode (default: testnet/paper trading)
# VITE_TESTNET_DEFAULT=false

# PostHog Analytics Configuration
# Get your project API key from https://app.posthog.com/settings/project
# VITE_POSTHOG_KEY=phc_your_api_key_here
# VITE_POSTHOG_HOST=https://app.posthog.com
