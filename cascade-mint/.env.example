# Environment variables for cascade-mint

# Mint configuration
MINT_URL=http://localhost:8080

# Database
DATABASE_PATH=./data/mint.db

# Signing key
SEED_PATH=./data/seed.key

# LND configuration (optional)
LND_HOST=
LND_PORT=10009
LND_TLS_CERT_PATH=
LND_MACAROON_PATH=

# Network
NETWORK=bitcoin

# Server
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080

# Logging
RUST_LOG=info,cascade_mint=debug

# Nostr
NOSTR_RELAY_URLS=wss://relay.damus.io,wss://relay.nostr.bg
NOSTR_RELAYS=
NOSTR_PRIVATE_KEY=
