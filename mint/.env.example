# Cascade Mint Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# MINT CONFIGURATION
# =============================================================================

# Master seed for the mint (32-byte hex string)
# Generate with: openssl rand -hex 32
MINT_PRIVATE_KEY=

# =============================================================================
# DATABASE
# =============================================================================

# SQLite database path (relative to WorkingDirectory)
# Default: data/cascade_mint.db
DATABASE_URL=sqlite:///data/cascade_mint.db

# =============================================================================
# LND / LIGHTNING CONFIGURATION
# =============================================================================

# LND gRPC endpoint
LND_GRPC_URL=https://localhost:10009

# Path to LND TLS certificate
LND_CERT_PATH=/opt/cascade-mint/certs/tls.cert

# Path to LND admin macaroon (hex-encoded)
LND_MACAROON_PATH=/opt/cascade-mint/macaroons/admin.macaroon

# Optional: absolute path to lncli when it is not on PATH
LND_CLI_PATH=/usr/local/bin/lncli

# Alternative: Hex-encoded macaroon directly
# LND_MACAROON=

# =============================================================================
# STRIPE CONFIGURATION (Optional)
# =============================================================================

# Stripe secret API key for hosted Checkout funding
STRIPE_SECRET_KEY=

# Stripe webhook signing secret for /api/portfolio/funding/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# Return URL after successful Checkout; {FUNDING_ID} is replaced by the mint
STRIPE_SUCCESS_URL=https://cascade.f7z.io/portfolio?stripe=success&funding_id={FUNDING_ID}

# Return URL after cancelled Checkout; {FUNDING_ID} is replaced by the mint
STRIPE_CANCEL_URL=https://cascade.f7z.io/portfolio?stripe=cancel&funding_id={FUNDING_ID}

# Optional override for API base URL, useful in tests
STRIPE_BASE_URL=https://api.stripe.com

# Checkout session lifetime in seconds
STRIPE_CHECKOUT_EXPIRY_SECONDS=1800

# Product name shown in hosted Checkout
STRIPE_PRODUCT_NAME=Cascade Portfolio Funding

# Conservative launch cap per Stripe Checkout funding request, in USD cents
STRIPE_MAX_FUNDING_MINOR=10000

# Legacy alias still accepted by the mint for backward compatibility
# STRIPE_MAX_TOPUP_MINOR=10000

# Conservative rolling Stripe volume cap per pubkey, in USD cents
STRIPE_WINDOW_LIMIT_MINOR=25000

# Rolling Stripe volume window length in seconds
STRIPE_WINDOW_SECONDS=86400

# Comma-separated Stripe risk levels allowed to mint portable proofs
STRIPE_ALLOWED_RISK_LEVELS=normal

# =============================================================================
# LOGGING
# =============================================================================

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# Enable backtrace on panic
RUST_BACKTRACE=1

# =============================================================================
# NETWORK
# =============================================================================

# Host to bind to (default: 127.0.0.1 for localhost only)
# Set to 0.0.0.0 for external access (behind reverse proxy)
HOST=127.0.0.1

# Port to listen on
PORT=8080

# =============================================================================
# NOSTR (Optional)
# =============================================================================

# Nostr relay URLs for trade event publishing (comma-separated)
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# =============================================================================
# SECURITY
# =============================================================================

# CORS allowed origins (comma-separated, no spaces)
# CORS_ORIGINS=https://cascade.f7z.io,https://www.cascade.f7z.io

# Enable rate limiting
ENABLE_RATE_LIMIT=true

# =============================================================================
# METRICS & MONITORING
# =============================================================================

# Enable Prometheus metrics endpoint
# METRICS_ENABLED=true
# METRICS_PORT=9090

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================

# Set to "true" to use mock Lightning (for testing only!)
# MOCK_LIGHTNING=true
