[mint]
url = "https://mint.f7z.io"
name = "Cascade Mainnet Mint"
description = "Mainnet mint for Cascade"

[database]
path = "./data/mainnet/cascade_mint.db"

[seed]
path = "./data/mainnet/mint_seed.key"

[lnd]
host = "127.0.0.1"
port = 10009
cert_path = "/Users/customer/.lnd/tls.cert"
macaroon_path = "/Users/customer/.lnd/data/chain/bitcoin/mainnet/admin.macaroon"
cli_path = "/Users/customer/bin/lncli"

[stripe]
secret_key = ""
webhook_secret = ""
success_url = "https://cascade.f7z.io/portfolio?stripe=success&funding_id={FUNDING_ID}"
cancel_url = "https://cascade.f7z.io/portfolio?stripe=cancel&funding_id={FUNDING_ID}"
base_url = "https://api.stripe.com"
checkout_expiry_seconds = 1800
product_name = "Cascade Portfolio Funding"
max_funding_minor = 10000
window_limit_minor = 25000
window_seconds = 86400
allowed_risk_levels = ["normal"]

[network]
network_type = "mainnet"

[server]
host = "127.0.0.1"
port = 3338

[fees]
trade_fee_percent = 1
