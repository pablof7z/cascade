# Cascade Mint Configuration

[mint]
url = "https://mint.f7z.io"
name = "Cascade Markets Mint"
description = "Cashu mint for Cascade prediction markets"

[database]
path = "./data/cascade_mint.db"

[seed]
path = "./data/mint_seed.key"

[lnd]
host = "127.0.0.1"
port = 10009
cert_path = "/path/to/tls.cert"
macaroon_path = "/path/to/admin.macaroon"
cli_path = "/path/to/lncli"

[fx]
quote_ttl_seconds = 900
max_provider_spread_bps = 500
max_observation_age_seconds = 60
min_provider_count = 2
usd_to_msat_spread_bps = 100
msat_to_usd_spread_bps = 100
signet_fallback_btc_usd_price = 50000.0

[stripe]
secret_key = ""
webhook_secret = ""
success_url = "https://cascade.f7z.io/portfolio?stripe=success&funding_id={FUNDING_ID}"
cancel_url = "https://cascade.f7z.io/portfolio?stripe=cancel&funding_id={FUNDING_ID}"
base_url = "https://api.stripe.com"
checkout_expiry_seconds = 1800
product_name = "Cascade Portfolio Funding"
max_funding_minor = 10000
window_limit_minor = 25000
window_seconds = 86400
allowed_risk_levels = ["normal"]

[network]
network_type = "testnet"

[server]
host = "127.0.0.1"
port = 3338

[fees]
trade_fee_percent = 1
