# Cascade Mint Configuration

[mint]
url = "https://mint.f7z.io"
name = "Cascade Markets Mint"
description = "Cashu mint for Cascade prediction markets"

[database]
path = "./data/cascade_mint.db"

[seed]
path = "./data/mint_seed.key"

[lnd]
host = "127.0.0.1"
port = 10009
cert_path = "/path/to/tls.cert"
macaroon_path = "/path/to/admin.macaroon"
cli_path = "/path/to/lncli"

[stripe]
secret_key = ""
webhook_secret = ""
success_url = "https://cascade.f7z.io/portfolio?stripe=success&topup_id={TOPUP_ID}"
cancel_url = "https://cascade.f7z.io/portfolio?stripe=cancel&topup_id={TOPUP_ID}"
base_url = "https://api.stripe.com"
checkout_expiry_seconds = 1800
product_name = "Cascade Portfolio Top-up"
max_topup_minor = 10000
window_limit_minor = 25000
window_seconds = 86400
allowed_risk_levels = ["normal"]

[network]
network_type = "testnet"

[server]
host = "127.0.0.1"
port = 3338

[fees]
trade_fee_percent = 1
